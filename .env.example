# Aurora Environment Variables
# Copy this file to .env and fill in your keys

# LLM Provider
AURORA_LLM_API_KEY=sk-your-api-key-here
AURORA_LLM_MODEL=deepseek-v4-flash
AURORA_LLM_BASE_URL=https://api.deepseek.com
AURORA_LLM_PROVIDER=deepseek

# Vision Fallback (optional)
AURORA_VISION_API_KEY=
AURORA_VISION_MODEL=gpt-4o-mini

# Server
AURORA_HOST=127.0.0.1
AURORA_PORT=9876
