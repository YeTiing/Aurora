# Aurora Sandbox — 代码执行隔离环境
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    nodejs npm \
    git \
    curl \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g typescript ts-node

WORKDIR /workspace

# 默认启动空循环保持容器运行
CMD ["tail", "-f", "/dev/null"]